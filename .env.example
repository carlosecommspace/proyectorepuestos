DATABASE_URL="file:./dev.db"
NEXTAUTH_SECRET="change-this-to-a-random-secret-in-production"
NEXTAUTH_URL="http://localhost:3000"

# AI Provider Configuration
# Option 1: Ollama (free, local) - default
AI_PROVIDER="ollama"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3"

# Option 2: OpenAI-compatible API (uncomment and configure)
# AI_PROVIDER="openai"
# OPENAI_API_KEY="your-key-here"
# OPENAI_BASE_URL="https://api.openai.com/v1"
# OPENAI_MODEL="gpt-3.5-turbo"

# Option 3: Claude/Anthropic API (uncomment and configure)
# AI_PROVIDER="claude"
# ANTHROPIC_API_KEY="your-key-here"
# ANTHROPIC_MODEL="claude-haiku-4-5-20251001"
